      "boundElements": [],
      "updated": 1780747377826,
      "link": null,
      "locked": false,
      "text": "Because a list a mutable object , each time we call the function without giving a value \nto my_list , we will modify the my_list created during fct definition (apply also for classes)\nand all mutable objects (dict for ex)",
      "fontSize": 18.672064777327932,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Because a list a mutable object , each time we call the function without giving a value \nto my_list , we will modify the my_list created during fct definition (apply also for classes)\nand all mutable objects (dict for ex)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "60yYzdShWhYhsSPqqqZsc",
      "type": "text",
      "x": 142.7134956837435,
      "y": -467.6382359612131,
      "width": 766.9737763535691,
      "height": 46.68016194331983,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
