      "index": "ao",
      "roundness": null,
      "seed": 1956351217,
      "version": 298,
      "versionNonce": 1192710833,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1780747377826,
      "link": null,
      "locked": false,
      "text": "dictionaries are PASSED by reference not value ! when passing a dictionnaries into a\nfunction it is not the value that get passed , but the memory adress of it  ",
      "fontSize": 18.672064777327932,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "dictionaries are PASSED by reference not value ! when passing a dictionnaries into a\nfunction it is not the value that get passed , but the memory adress of it  ",
      "autoResize": true,
      "lineHeight": 1.25
    },
